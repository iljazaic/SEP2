<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.SignUpController" alignment="TOP_CENTER" spacing="14" style="-fx-background-color: #F1F5F9;">
    <padding><Insets top="48" right="30" bottom="24" left="30"/></padding>
    <Label text="✈" style="-fx-font-size: 52; -fx-text-fill: #4F46E5;"/>
    <Label text="Create account" style="-fx-font-size: 30; -fx-font-weight: 900; -fx-text-fill: #020617;"/>
    <Label text="Sign up to find your next destination" style="-fx-font-size: 12; -fx-text-fill: #64748B;"/>
    <Region prefHeight="12"/>
    <TextField fx:id="nameField" prefHeight="54" style="-fx-background-color: white; -fx-background-radius: 16;"/>
    <TextField fx:id="emailField" prefHeight="54" style="-fx-background-color: white; -fx-background-radius: 16;"/>
    <PasswordField fx:id="passwordField" prefHeight="54" style="-fx-background-color: white; -fx-background-radius: 16;"/>
    <PasswordField fx:id="confirmPasswordField" prefHeight="54" style="-fx-background-color: white; -fx-background-radius: 16;"/>
    <Button text="Sign Up" onAction="#createAccount" maxWidth="Infinity" prefHeight="56" style="-fx-background-color: #0F172A; -fx-text-fill: white; -fx-background-radius: 18; -fx-font-weight: bold;"/>
    <Region prefHeight="32"/>
    <Hyperlink text="Already have an account? Login" onAction="#backToLogin"/>
</VBox>
