<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.student.flygo.controller.PaymentController" spacing="14" style="-fx-background-color: #F1F5F9;">
    <fx:define>
        <ToggleGroup fx:id="paymentGroup"/>
    </fx:define>
    <padding><Insets top="42" right="24" bottom="20" left="24"/></padding>
    <Label text="Payment" style="-fx-font-size: 27; -fx-font-weight: 900; -fx-text-fill: #020617;"/>
    <Label text="Choose your payment method" style="-fx-font-size: 11; -fx-text-fill: #64748B;"/>
    <VBox spacing="18" prefHeight="178" style="-fx-background-color: #4F46E5; -fx-background-radius: 24; -fx-padding: 22;">
        <Label text="Visa Card" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Label text="•••• •••• •••• 2489" style="-fx-font-size: 22; -fx-font-weight: 900; -fx-text-fill: white;"/>
        <HBox>
            <Label fx:id="cardNameLabel" style="-fx-font-size: 11; -fx-text-fill: #E0E7FF;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="12/28" style="-fx-font-size: 11; -fx-text-fill: #E0E7FF;"/>
        </HBox>
    </VBox>
    <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 28; -fx-padding: 18;">
        <RadioButton fx:id="creditRadio" text="Credit Card" toggleGroup="$paymentGroup" style="-fx-font-weight: bold;"/>
        <Separator/>
        <RadioButton fx:id="appleRadio" text="Apple Pay" toggleGroup="$paymentGroup" style="-fx-font-weight: bold;"/>
        <Separator/>
        <RadioButton fx:id="paypalRadio" text="PayPal" toggleGroup="$paymentGroup" style="-fx-font-weight: bold;"/>
    </VBox>
    <Region VBox.vgrow="ALWAYS"/>
    <Button fx:id="payButton" onAction="#pay" maxWidth="Infinity" prefHeight="56" style="-fx-background-color: #0F172A; -fx-text-fill: white; -fx-background-radius: 18; -fx-font-weight: bold;"/>
    <Button text="Back" onAction="#back" maxWidth="Infinity" prefHeight="42" style="-fx-background-color: #4F46E5; -fx-text-fill: white; -fx-background-radius: 16;"/>
</VBox>
