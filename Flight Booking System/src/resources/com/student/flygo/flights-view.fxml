<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.FlightController" spacing="14" style="-fx-background-color: #F1F5F9;">
    <padding><Insets top="42" right="24" bottom="20" left="24"/></padding>
    <HBox alignment="CENTER_LEFT">
        <VBox>
            <Label text="Available flights" style="-fx-font-size: 27; -fx-font-weight: 900; -fx-text-fill: #020617;"/>
            <Label fx:id="subtitleLabel" style="-fx-font-size: 11; -fx-text-fill: #64748B;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="☰" prefWidth="42" prefHeight="42" style="-fx-background-color: white; -fx-background-radius: 15;"/>
    </HBox>
    <HBox fx:id="filterBox" spacing="7"/>
    <VBox fx:id="flightsBox" spacing="12"/>
    <Button text="Back" onAction="#back" maxWidth="Infinity" prefHeight="42" style="-fx-background-color: #0F172A; -fx-text-fill: white; -fx-background-radius: 16;"/>
</VBox>
