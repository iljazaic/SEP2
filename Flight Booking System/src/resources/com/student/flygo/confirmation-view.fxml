<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.student.flygo.controller.ConfirmationController" alignment="TOP_CENTER" spacing="17" style="-fx-background-color: #F1F5F9;">
    <padding><Insets top="64" right="24" bottom="20" left="24"/></padding>
    <Label text="✓" style="-fx-background-color: #10B981; -fx-background-radius: 44; -fx-padding: 12 26 12 26; -fx-text-fill: white; -fx-font-size: 48; -fx-font-weight: bold;"/>
    <Label text="Booking Confirmed!" style="-fx-font-size: 29; -fx-font-weight: 900; -fx-text-fill: #020617;"/>
    <Label fx:id="subtitleLabel" style="-fx-font-size: 11; -fx-text-fill: #64748B;"/>
    <VBox spacing="8" maxWidth="345" style="-fx-background-color: white; -fx-background-radius: 28; -fx-padding: 24;">
        <Label fx:id="flightLabel" style="-fx-font-size: 20; -fx-font-weight: 900;"/>
        <Label fx:id="routeLabel" style="-fx-font-size: 27; -fx-font-weight: 900;"/>
        <HBox><Label text="Date:" style="-fx-text-fill: #64748B;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="dateLabel"/></HBox>
        <HBox><Label text="Time:" style="-fx-text-fill: #64748B;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="timeLabel"/></HBox>
        <HBox><Label text="Passenger:" style="-fx-text-fill: #64748B;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="passengerLabel"/></HBox>
        <HBox><Label text="Passengers:" style="-fx-text-fill: #64748B;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="passengersLabel"/></HBox>
        <HBox><Label text="Seat:" style="-fx-text-fill: #64748B;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="seatLabel"/></HBox>
        <HBox><Label text="Baggage:" style="-fx-text-fill: #64748B;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="baggageLabel"/></HBox>
        <HBox><Label text="Payment:" style="-fx-text-fill: #64748B;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="paymentLabel"/></HBox>
        <HBox><Label text="Total:" style="-fx-font-weight: bold;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="totalLabel" style="-fx-font-weight: 900;"/></HBox>
        <Label text="Booking ID: FG28491" style="-fx-text-fill: #64748B;"/>
    </VBox>
    <Region VBox.vgrow="ALWAYS"/>
    <Button text="Back to Home" onAction="#backHome" maxWidth="Infinity" prefHeight="56" style="-fx-background-color: #4F46E5; -fx-text-fill: white; -fx-background-radius: 18; -fx-font-weight: bold;"/>
</VBox>
