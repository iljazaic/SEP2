<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.SeatController" spacing="14" style="-fx-background-color: #F1F5F9;">
    <padding><Insets top="42" right="24" bottom="20" left="24"/></padding>
    <Label text="Select your seat" style="-fx-font-size: 27; -fx-font-weight: 900; -fx-text-fill: #020617;"/>
    <Label fx:id="flightLabel" style="-fx-font-size: 11; -fx-text-fill: #64748B;"/>
    <VBox spacing="8" style="-fx-background-color: #0F172A; -fx-background-radius: 22; -fx-padding: 18;">
        <Label fx:id="routeLabel" style="-fx-font-size: 20; -fx-font-weight: 900; -fx-text-fill: white;"/>
        <Label text="Direct flight" style="-fx-font-size: 12; -fx-text-fill: #CBD5E1;"/>
    </VBox>
    <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 28; -fx-padding: 18;">
        <Label text="Choose your seat" style="-fx-font-size: 15; -fx-font-weight: bold;"/>
        <GridPane fx:id="seatGrid" alignment="CENTER" hgap="9" vgap="10" style="-fx-background-color: #1F2937; -fx-background-radius: 18; -fx-padding: 18;"/>
        <Label fx:id="selectedSeatLabel" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
        <Button text="Continue" onAction="#continueToSummary" maxWidth="Infinity" prefHeight="56" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-background-radius: 18; -fx-font-weight: bold;"/>
        <HBox alignment="CENTER" spacing="12">
            <Label text="Available" style="-fx-text-fill: #64748B; -fx-font-size: 10;"/>
            <Label text="Selected" style="-fx-text-fill: #64748B; -fx-font-size: 10;"/>
            <Label text="Taken" style="-fx-text-fill: #64748B; -fx-font-size: 10;"/>
        </HBox>
    </VBox>
    <Button text="Back" onAction="#back" maxWidth="Infinity" prefHeight="42" style="-fx-background-color: #0F172A; -fx-text-fill: white; -fx-background-radius: 16;"/>
</VBox>
